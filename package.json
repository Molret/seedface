{
	"name": "seedface",
	"version": "0.1.1",
	"description": "Modern, framework-agnostic deterministic placeholder avatar generator. React, Vue, Svelte, Web Components, CLI. Zero-dependency core.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		},
		"./webcomponent": {
			"types": "./dist/webcomponent.d.ts",
			"import": "./dist/webcomponent.js",
			"require": "./dist/webcomponent.cjs"
		},
		"./vue": {
			"types": "./src/vue/Avatar.vue.d.ts",
			"import": "./src/vue/Avatar.vue"
		},
		"./svelte": {
			"types": "./src/svelte/Avatar.svelte.d.ts",
			"import": "./src/svelte/Avatar.svelte"
		},
		"./cli": "./dist/cli.js"
	},
	"bin": {
		"seedface": "./dist/cli.js"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"demo": "vite --config demo/vite.config.ts",
		"test": "tsx test/run.ts",
		"prepublishOnly": "npm run build && npm test"
	},
	"keywords": [
		"avatar",
		"placeholder",
		"identicon",
		"react",
		"vue",
		"svelte",
		"web-component",
		"svg",
		"deterministic",
		"rsc"
	],
	"author": "Seedface",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/molret/seedface.git"
	},
	"homepage": "https://github.com/molret/seedface#readme",
	"bugs": {
		"url": "https://github.com/molret/seedface/issues"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"optionalDependencies": {
		"@resvg/resvg-js": "^2.6.2"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@vitejs/plugin-react": "^4.0.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"tsup": "^8.0.0",
		"tsx": "^4.0.0",
		"typescript": "^5.4.0",
		"vite": "^5.0.0"
	},
	"engines": {
		"node": ">=16"
	}
}
